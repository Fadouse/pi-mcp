{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/pi-mcp.schema.json",
  "title": "pi-mcp configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "searchLimit": { "type": "integer", "minimum": 1, "maximum": 10, "default": 3 },
        "maxOutputBytes": { "type": "integer", "minimum": 1, "default": 51200 },
        "maxOutputLines": { "type": "integer", "minimum": 1, "default": 2000 },
        "includeServerInstructions": { "type": "boolean", "default": true }
      }
    },
    "mcpServers": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/server" }
    }
  },
  "$defs": {
    "shared": {
      "type": "object",
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "enabled": { "type": "boolean", "default": true },
        "startupTimeoutMs": { "type": "integer", "minimum": 1, "default": 15000 },
        "toolTimeoutMs": { "type": "integer", "minimum": 1, "default": 60000 },
        "enabledTools": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "disabledTools": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "alwaysActiveTools": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "includeInstructions": { "type": "boolean" },
        "supportsParallelToolCalls": { "type": "boolean", "default": false }
      }
    },
    "stdio": {
      "allOf": [
        { "$ref": "#/$defs/shared" },
        {
          "type": "object",
          "required": ["command"],
          "properties": {
            "command": { "type": "string", "minLength": 1 },
            "args": { "type": "array", "items": { "type": "string" } },
            "env": { "type": "object", "additionalProperties": { "type": "string" } },
            "cwd": { "type": "string" }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "http": {
      "allOf": [
        { "$ref": "#/$defs/shared" },
        {
          "type": "object",
          "required": ["url"],
          "properties": {
            "url": { "type": "string", "format": "uri", "pattern": "^https?://" },
            "headers": { "type": "object", "additionalProperties": { "type": "string" } }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "disabled": {
      "type": "object",
      "required": ["enabled"],
      "properties": { "enabled": { "const": false } },
      "additionalProperties": false
    },
    "server": {
      "anyOf": [
        { "$ref": "#/$defs/disabled" },
        { "$ref": "#/$defs/stdio" },
        { "$ref": "#/$defs/http" }
      ]
    }
  }
}
